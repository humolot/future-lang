# Pokémon Explorer — PokeAPI + optional AI description
# PokeAPI is free and requires no API key
# AI description is optional — works without it too
#
# Usage:
#   future run examples/pokemon-ai.future
#
# Change the pokemon below — try: pikachu, charizard, mewtwo, snorlax, gengar

pokemon_name = "charizard"

print "==============================="
print "   Pokémon Explorer"
print "==============================="
print ""

try
  url = "https://pokeapi.co/api/v2/pokemon/{pokemon_name}"
  p   = http.get(url)

  name   = p.name
  height = p.height
  weight = p.weight
  exp    = p.base_experience

  print "Name             : {name}"
  print "Height           : {height} dm"
  print "Weight           : {weight} hg"
  print "Base experience  : {exp}"
  print ""

  # Types
  print "Types:"
  for type_slot in p.types
    type_obj  = type_slot.type
    type_name = type_obj.name
    print "  • {type_name}"
  end
  print ""

  # Base stats
  print "Base stats:"
  for stat_slot in p.stats
    stat_obj   = stat_slot.stat
    stat_name  = stat_obj.name
    stat_value = stat_slot.base_stat
    print "  {stat_name}: {stat_value}"
  end
  print ""

  # Abilities
  print "Abilities:"
  for ability_slot in p.abilities
    ability_obj  = ability_slot.ability
    ability_name = ability_obj.name
    print "  • {ability_name}"
  end
  print ""

  # AI battle description (requires a configured AI provider)
  try
    prompt      = "The pokémon {name} has {exp} base XP, height {height} dm and weight {weight} hg. Write an epic two-sentence battle description for it."
    description = ai.ask(prompt)
    print "─── AI Description ───"
    print description
    print ""
  catch ai_err
    print "(AI not configured — set ANTHROPIC_API_KEY or OPENAI_API_KEY to enable)"
  end

catch err
  print "Error: {err.message}"
  print "Check that the Pokémon name is correct (e.g. pikachu, charizard, mewtwo)"
end

print "Source: PokeAPI (pokeapi.co)"
