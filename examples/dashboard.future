# Dashboard Multi-API — Tudo de uma vez
# Combina: clima, crypto, Hacker News e IA numa única execução
# APIs gratuitas, sem chave (exceto a parte de IA)
#
# Uso:
#   future run examples/dashboard.future

print "╔══════════════════════════════════════════╗"
print "║            Dashboard Ao Vivo             ║"
print "╚══════════════════════════════════════════╝"
print ""

# ─── 1. Clima ────────────────────────────────────
print "☁  CLIMA — Lisboa"
print "───────────────────────"

try
  clima_url = "https://api.open-meteo.com/v1/forecast?latitude=38.7169&longitude=-9.1399&current_weather=true"
  clima     = http.get(clima_url)
  cw        = clima.current_weather
  temp      = cw.temperature
  vento     = cw.windspeed
  print "Temperatura : {temp} °C"
  print "Vento       : {vento} km/h"
catch err
  print "Clima indisponível: {err.message}"
end

print ""

# ─── 2. Crypto ───────────────────────────────────
print "₿  CRYPTO — Preços (USD)"
print "───────────────────────"

try
  btc_r  = http.get("https://api.coinbase.com/v2/prices/BTC-USD/spot")
  btc_d  = btc_r.data
  btc    = btc_d.amount
  print "Bitcoin (BTC) : $ {btc}"
catch err
  print "BTC indisponível"
end

try
  eth_r  = http.get("https://api.coinbase.com/v2/prices/ETH-USD/spot")
  eth_d  = eth_r.data
  eth    = eth_d.amount
  print "Ethereum (ETH): $ {eth}"
catch err
  print "ETH indisponível"
end

print ""

# ─── 3. Hacker News ──────────────────────────────
print "▲  HACKER NEWS — Top 3"
print "───────────────────────"

try
  ids   = http.get("https://hacker-news.firebaseio.com/v0/topstories.json")
  count = 0
  rank  = 1

  for id in ids
    if count < 3
      story_url = "https://hacker-news.firebaseio.com/v0/item/{id}.json"
      story     = http.get(story_url)
      titulo    = story.title
      pontos    = story.score
      print "{rank}. {titulo} ({pontos} pts)"
      count = count + 1
      rank  = rank + 1
    end
  end
catch err
  print "HN indisponível: {err.message}"
end

print ""

# ─── 4. Pokémon do dia ───────────────────────────
print "✦  POKÉMON DO DIA"
print "───────────────────────"

try
  pk_url = "https://pokeapi.co/api/v2/pokemon/ditto"
  pk     = http.get(pk_url)
  pk_nome = pk.name
  pk_peso = pk.weight
  pk_exp  = pk.base_experience
  print "Nome : {pk_nome}"
  print "Peso : {pk_peso} hg | XP base: {pk_exp}"
catch err
  print "PokeAPI indisponível"
end

print ""

# ─── 5. Dica do dia via IA ───────────────────────
print "★  DICA DO DIA (IA)"
print "───────────────────────"

try
  dica = ai.ask("Dê uma dica curta de produtividade para desenvolvedores em exatamente uma frase.")
  print dica
catch err
  print "(Configure ANTHROPIC_API_KEY ou OPENAI_API_KEY para ativar)"
end

print ""
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
print "Dashboard atualizado. Execute novamente para refrescar."
