# Live Dashboard — multiple APIs in one run
# Combines weather, crypto, Hacker News, and AI in a single execution
# All APIs are free and require no key (except the AI tip section)
#
# Usage:
#   future run examples/dashboard.future

print "╔══════════════════════════════════════════╗"
print "║              Live Dashboard              ║"
print "╚══════════════════════════════════════════╝"
print ""

# ─── Weather ─────────────────────────────────────
print "☁  WEATHER — Lisbon"
print "───────────────────────"

try
  climate_url = "https://api.open-meteo.com/v1/forecast?latitude=38.7169&longitude=-9.1399&current_weather=true"
  climate     = http.get(climate_url)
  cw          = climate.current_weather
  temp        = cw.temperature
  wind        = cw.windspeed
  print "Temperature : {temp} °C"
  print "Wind        : {wind} km/h"
catch err
  print "Weather unavailable: {err.message}"
end

print ""

# ─── Crypto ──────────────────────────────────────
print "₿  CRYPTO — Prices (USD)"
print "───────────────────────"

try
  btc_r = http.get("https://api.coinbase.com/v2/prices/BTC-USD/spot")
  btc_d = btc_r.data
  btc   = btc_d.amount
  print "Bitcoin (BTC)  : $ {btc}"
catch err
  print "BTC unavailable"
end

try
  eth_r = http.get("https://api.coinbase.com/v2/prices/ETH-USD/spot")
  eth_d = eth_r.data
  eth   = eth_d.amount
  print "Ethereum (ETH) : $ {eth}"
catch err
  print "ETH unavailable"
end

print ""

# ─── Hacker News ─────────────────────────────────
print "▲  HACKER NEWS — Top 3"
print "───────────────────────"

try
  ids   = http.get("https://hacker-news.firebaseio.com/v0/topstories.json")
  count = 0
  rank  = 1

  for id in ids
    if count < 3
      story_url = "https://hacker-news.firebaseio.com/v0/item/{id}.json"
      story     = http.get(story_url)
      title     = story.title
      score     = story.score
      print "{rank}. {title} ({score} pts)"
      count = count + 1
      rank  = rank + 1
    end
  end
catch err
  print "HN unavailable: {err.message}"
end

print ""

# ─── Pokémon of the day ──────────────────────────
print "✦  POKÉMON OF THE DAY"
print "───────────────────────"

try
  pk_url  = "https://pokeapi.co/api/v2/pokemon/ditto"
  pk      = http.get(pk_url)
  pk_name = pk.name
  pk_wt   = pk.weight
  pk_exp  = pk.base_experience
  print "Name : {pk_name}"
  print "Weight : {pk_wt} hg  |  Base XP : {pk_exp}"
catch err
  print "PokeAPI unavailable"
end

print ""

# ─── AI tip of the day ───────────────────────────
print "★  TIP OF THE DAY (AI)"
print "───────────────────────"

try
  tip = ai.ask("Give one short productivity tip for developers in exactly one sentence.")
  print tip
catch err
  print "(Set ANTHROPIC_API_KEY or OPENAI_API_KEY to enable)"
end

print ""
print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
print "Dashboard refreshed. Run again to update."
