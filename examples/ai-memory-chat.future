# Multi-turn AI Chat with accumulated context
# Each question carries the context of previous answers
# Also demonstrates ai.complete() to inspect token usage
#
# Usage:
#   future run examples/ai-memory-chat.future
#
# Requires an AI provider:
#   export ANTHROPIC_API_KEY=sk-ant-...
#   export OPENAI_API_KEY=sk-...
#   # or run Ollama locally (free): https://ollama.ai

print "╔════════════════════════════════════╗"
print "║   Multi-turn AI Chat + Memory     ║"
print "╚════════════════════════════════════╝"
print ""

try
  # ─── Turn 1 — introduction ──────────────────────────────────
  q1 = "I have 3 years of Python experience and want to learn a second language. What do you recommend and why? (answer in 2 sentences)"
  print "User: {q1}"
  a1 = ai.ask(q1)
  print "  AI: {a1}"
  print ""

  memory.set("turn_1_answer", a1)

  # ─── Turn 2 — follow-up with context ────────────────────────
  context1 = "A developer with 3 years of Python got this recommendation: {a1}"
  q2       = "{context1}. They now ask: What is the best free resource to get started? (1 sentence)"
  print "User: What is the best free resource to get started?"
  a2 = ai.ask(q2)
  print "  AI: {a2}"
  print ""

  memory.set("turn_2_answer", a2)

  # ─── Turn 3 — ai.complete() to get token usage ──────────────
  context2 = "Advice given so far: {a1} Resource suggested: {a2}"
  q3       = "{context2}. One final motivational sentence to start today."
  print "User: Give me one motivational sentence to start today."

  result  = ai.complete(q3)
  final   = result.text
  tokens  = result.tokens
  total   = tokens.total

  print "  AI: {final}"
  print ""

  # ─── Session summary ────────────────────────────────────────
  t1 = memory.get("turn_1_answer")
  t2 = memory.get("turn_2_answer")

  print "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  print "Session complete:"
  print "  3 turns with accumulated context"
  print "  Tokens used (last turn): {total}"
  print "  Provider: {result.provider} | Model: {result.model}"
  print ""
  print "Stored in session memory:"
  print "  T1: {t1}"
  print "  T2: {t2}"

catch err
  print "AI error: {err.message}"
  print ""
  print "Configure your API key:"
  print "  export ANTHROPIC_API_KEY=sk-ant-..."
  print "  export OPENAI_API_KEY=sk-..."
  print "  # Ollama (free, local): https://ollama.ai"
end
