{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(if\\b|else\\b|else\\s+if\\b|function\\b|for\\b.*\\bin\\b|while\\b|try\\b|catch\\b|on\\b|every\\b|stream\\b|agent\\b)",
    "decreaseIndentPattern": "^\\s*(end|else|catch)\\b"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*(if|else|else if|function|for|while|try|catch|on|every|stream|agent)\\b.*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*end\\b",
      "action": {
        "indent": "outdent"
      }
    }
  ]
}
