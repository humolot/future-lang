{
  "name": "future-lang-vscode",
  "displayName": "Future Lang",
  "description": "Syntax highlighting, snippets, and language server for the Future programming language",
  "version": "0.6.0",
  "publisher": "humolot",
  "license": "MIT",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "future",
    "future-lang",
    "ai",
    "iot",
    "language",
    "transpiler",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/humolot/future-lang.git"
  },
  "homepage": "https://github.com/humolot/future-lang#readme",
  "bugs": {
    "url": "https://github.com/humolot/future-lang/issues"
  },
  "activationEvents": [
    "onLanguage:future"
  ],
  "contributes": {
    "languages": [
      {
        "id": "future",
        "aliases": [
          "Future",
          "future"
        ],
        "extensions": [
          ".future"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "future",
        "scopeName": "source.future",
        "path": "./syntaxes/future.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "future",
        "path": "./snippets/future.json"
      }
    ]
  },
  "dependencies": {
    "future-lang": "^0.6.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  }
}
